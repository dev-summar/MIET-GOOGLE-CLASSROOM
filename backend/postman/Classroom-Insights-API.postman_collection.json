{
  "info": {
    "name": "Classroom Insights API",
    "description": "Test the Node.js backend. Base URL: http://localhost:8000/api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000/api" }
  ],
  "item": [
    {
      "name": "1. Health & Debug",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "No auth/DB needed. Confirms server is running."
          }
        },
        {
          "name": "Debug — Auth status",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/debug/auth-status",
            "description": "Checks Google credentials and impersonation."
          }
        },
        {
          "name": "Debug — DB status",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/debug/db-status",
            "description": "Pings MongoDB. Requires valid MONGODB_URI."
          }
        },
        {
          "name": "Debug — DB source",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/debug/db-source",
            "description": "Collection counts and masked Mongo URI."
          }
        },
        {
          "name": "Debug — Clear DB",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/debug/clear-db",
            "description": "Empty all collections (courses, teachers, students, coursework, submissions). Then run Sync all for a fresh sync."
          }
        }
      ]
    },
    {
      "name": "2. Sync",
      "item": [
        {
          "name": "Sync all",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/sync/all",
            "description": "Full sync: courses (≥2025), teachers, students, coursework, submissions. Invalidates cache."
          }
        }
      ]
    },
    {
      "name": "3. Stats & Lists",
      "item": [
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/stats",
            "description": "Counts: courses, students, teachers, assignments, submissions (active courses only)."
          }
        },
        {
          "name": "Courses (paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/courses?page=1&limit=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["courses"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" }
              ]
            },
            "description": "List active courses. Optional: page, limit, search (case-insensitive)."
          }
        },
        {
          "name": "Course by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/courses/:courseId",
              "host": ["{{baseUrl}}"],
              "path": ["courses", ":courseId"],
              "variable": [{ "key": "courseId", "value": "" }]
            },
            "description": "Replace :courseId with a real course id from /courses."
          }
        },
        {
          "name": "Students",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/students?page=1&limit=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["students"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Teachers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/teachers?page=1&limit=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["teachers"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Assignments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/assignments?page=1&limit=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["assignments"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Assignment by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/assignments/:id",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "description": "Replace :id with assignment id. Optional query: page, limit for submissions."
          }
        }
      ]
    },
    {
      "name": "4. Analytics",
      "item": [
        {
          "name": "Silent students",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/silent-students?page=1&limit=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["silent-students"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" }
              ]
            },
            "description": "Students with zero submissions or no activity in last 30 days."
          }
        },
        {
          "name": "At-risk students",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/at-risk-students?page=1&limit=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["at-risk-students"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" }
              ]
            },
            "description": "Missed ≥40%, or 2+ consecutive missing, or submission rate < 60%."
          }
        }
      ]
    }
  ]
}
